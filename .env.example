# PI_AI Local Server Configuration
# Copy this to .env and fill in your values

# ==================== SERVER ====================
PORT=3000

# ==================== LLM CONFIGURATION ====================
# Choose one of: "ollama" (default), "openai", or "mistral"
LLM_PROVIDER=ollama

# Ollama (Local)
# If using Ollama, make sure it's running: ollama serve
LLM_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
LLM_MODEL=llama3

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo

# Mistral AI
# LLM_PROVIDER=mistral
# LLM_API_URL=https://api.mistral.ai/v1/chat/completions
# MISTRAL_API_KEY=your-mistral-api-key
# MISTRAL_MODEL=mistral-large-latest

# Generic LLM config (fallback)
LLM_API_KEY=

# ==================== APIFY SHERLOCK ====================
# Get your token at: https://console.apify.com/account/integrations
# Sherlock is used for username reconnaissance across social platforms
APIFY_API_TOKEN=

# ==================== TRAUMA-INFORMED SETTINGS ====================
# These are embedded in the application; modify in README.md or here if needed
NODE_ENV=production
